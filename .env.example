# =============================================================================
# FutuRole Growth Copilot — environment variables
# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).
# =============================================================================

# --- Core ---------------------------------------------------------------------
# PostgreSQL connection string.
#   Docker (recommended):  postgresql://postgres:postgres@localhost:5432/futurole_growth?schema=public
#   Native (this machine): postgresql://postgres@localhost:5433/futurole_growth?schema=public
DATABASE_URL=

# Password for the single-user dashboard login (middleware gate).
APP_PASSWORD=

# --- LLM (Google Gemini) ------------------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Reddit (snoowrap, script app) -------------------------------------------
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Reddit requires a descriptive UA, e.g. "web:futurole-growth-copilot:v1 (by /u/yourname)"
REDDIT_USER_AGENT=

# --- Stripe -------------------------------------------------------------------
# Secret key from https://dashboard.stripe.com/apikeys (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# --- Telegram alerts ----------------------------------------------------------
# Create a bot via @BotFather; get the chat id by messaging the bot then
# calling https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- FutuRole integrations ----------------------------------------------------
# Optional: existing FutuRole ATS scoring API. If unset, a local keyword-based
# fallback scorer is used.
FUTUROLE_ATS_API_URL=
FUTUROLE_ATS_API_KEY=
# Shared secret to authenticate the signup webhook (X-FutuRole-Signature header).
FUTUROLE_WEBHOOK_SECRET=

# --- Discord (v2 — not yet active) -------------------------------------------
DISCORD_BOT_TOKEN=

# --- Tunables -----------------------------------------------------------------
# Minimum intentScore (0-100) to keep an opportunity (below => SKIPPED). Default 70.
TRIAGE_SCORE_THRESHOLD=70
# intentScore (0-100) that triggers an instant Telegram "hot lead" alert. Default 90.
HOT_LEAD_THRESHOLD=90
# Anti-ban: minimum helpful replies per link-bearing reply. Default 9 (=> 9:1).
HELPFUL_TO_LINK_RATIO=9
# Public URL of the free ATS scanner that drafts link to. Default futurole.com/ats-scan
FUTUROLE_SCANNER_URL=https://futurole.com/ats-scan

# --- Cron protection (extra, beyond the brief) --------------------------------
# If set, /api/cron/* require `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this header automatically when CRON_SECRET is configured.
CRON_SECRET=
